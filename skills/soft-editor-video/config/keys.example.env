# Copie este arquivo para config/keys.env e preencha com SUAS chaves.
# O agente faz isso automaticamente no onboarding. NUNCA comite o keys.env.

# OpenAI: imagens (gpt-image-2). Obrigatória.
# A transcrição NÃO usa mais essa chave: roda local no whisper.cpp, custo zero (ver PASSO 0.4 da SKILL).
OPENAI_API_KEY=sk-...

# Google AI / Gemini: Veo 3.1 fast. Obrigatória.
# Pode colocar VÁRIAS chaves separadas por vírgula (o agente rotaciona quando uma estoura a quota).
GEMINI_API_KEYS=AIza...,AIza...

# Submagic: legenda automática PAGA. Opcional e secundária.
# O padrão da casa é a legenda karaokê própria (07_karaoke.py, custo zero); só use se preferir a paga.
SUBMAGIC_API_KEY=

# Modelo do whisper.cpp local (small padrão; medium = PT-BR mais fiel). Opcional.
WHISPER_MODEL=small

# Pasta onde salvar os vídeos prontos (deixe em branco pra usar ./output)
OUTPUT_DIR=
