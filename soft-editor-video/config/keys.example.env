# Copie este arquivo para config/keys.env e preencha com SUAS chaves.
# O agente faz isso automaticamente no onboarding. NUNCA comite o keys.env.

# OpenAI — imagens (gpt-image-2) + transcrição (Whisper). Obrigatória.
OPENAI_API_KEY=sk-...

# Google AI / Gemini — Veo 3.1 fast. Obrigatória.
# Pode colocar VÁRIAS chaves separadas por vírgula (o agente rotaciona quando uma estoura a quota).
GEMINI_API_KEYS=AIza...,AIza...

# Submagic — legenda automática. Opcional (só se o vídeo não vier legendado).
SUBMAGIC_API_KEY=

# Pasta onde salvar os vídeos prontos (deixe em branco pra usar ./output)
OUTPUT_DIR=
